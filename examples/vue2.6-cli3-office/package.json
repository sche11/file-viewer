{
  "name": "file-viewer-vue26-cli3-office-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "npm run copy:file-viewer-assets && vue-cli-service serve --mode normalServe",
    "build": "npm run copy:file-viewer-assets && vue-cli-service build --mode normalBuild",
    "noApiServe": "npm run copy:file-viewer-assets && vue-cli-service serve --mode noApiServe",
    "noApiBuild": "npm run copy:file-viewer-assets && vue-cli-service build --mode noApiBuild",
    "nginx": "npm run copy:file-viewer-assets && vue-cli-service build --mode nginx",
    "analyz": "npm_config_report=true npm run build",
    "copy:file-viewer-assets": "node scripts/copy-file-viewer-assets.cjs"
  },
  "dependencies": {
    "@file-viewer/preset-office": "^2.2.0",
    "@file-viewer/vue2.6": "^2.2.0",
    "ant-design-vue": "^1.7.2",
    "axios": "^0.18.0",
    "babel-polyfill": "^6.26.0",
    "element-ui": "^2.13.2",
    "file-saver": "^2.0.5",
    "moment": "^2.29.4",
    "nprogress": "^0.2.0",
    "screenfull": "^5.1.0",
    "vue": "2.6.14",
    "vue-router": "^3.0.1",
    "vuex": "^3.1.1",
    "xlsx": "^0.17.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/preset-env": "^7.28.5",
    "@vue/cli-plugin-babel": "^3.1.1",
    "@vue/cli-service": "^3.1.4",
    "babel-loader": "^8.4.1",
    "compression-webpack-plugin": "^1.1.12",
    "css-loader": "^2.1.0",
    "style-loader": "^2.0.0",
    "uglifyjs-webpack-plugin": "^2.2.0",
    "vue-template-compiler": "2.6.14",
    "webpack-bundle-analyzer": "^3.0.3"
  },
  "browserslist": [
    "Chrome >= 80",
    "Firefox >= 78",
    "Safari >= 13",
    "Edge >= 80"
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/flyfish-dev/file-viewer/releases/download/v2.1.18/release-matrix.schema.json",
  "title": "Flyfish File Viewer ecosystem release matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedFrom",
    "version",
    "releasePolicy",
    "counts",
    "packageGroups",
    "releaseChannels",
    "productionTargets",
    "surfaces",
    "packages",
    "componentTargets",
    "renderChains",
    "wrapperFamilyTargets",
    "matrixTargets",
    "specialBrowserChecks",
    "assetFamilies"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "generatedFrom": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootPackageHash",
        "releaseMatrixSchema",
        "wrapperManifest",
        "smokeMatrix",
        "rendererDefinitions"
      ],
      "properties": {
        "rootPackageHash": { "type": "string" },
        "releaseMatrixSchema": {
          "type": "string",
          "const": "ecosystem/release-matrix.schema.json"
        },
        "wrapperManifest": {
          "type": "string",
          "const": "ecosystem/wrappers.json"
        },
        "smokeMatrix": {
          "type": "string",
          "const": "ecosystem/smoke-matrix.json"
        },
        "rendererDefinitions": {
          "type": "string",
          "const": "packages/core/src/registry/formats.ts"
        }
      }
    },
    "version": { "type": "string" },
    "releasePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultBlocking",
        "nonBlockingChannels",
        "externalRuntimeAssets",
        "fullPackagePresetPolicy",
        "standardPackagePresetPolicy"
      ],
      "properties": {
        "defaultBlocking": { "type": "boolean", "const": true },
        "nonBlockingChannels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "externalRuntimeAssets": {
          "type": "string",
          "const": "forbidden"
        },
        "fullPackagePresetPolicy": {
          "type": "string",
          "const": "preset-all-by-default"
        },
        "standardPackagePresetPolicy": {
          "type": "string",
          "const": "explicit-preset-all"
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packages",
        "componentTargets",
        "surfaces",
        "renderChains",
        "rendererIds",
        "uniqueExtensions",
        "wrapperFamilyTargets",
        "exhaustiveComponentRenderTargets"
      ],
      "properties": {
        "packages": { "type": "integer" },
        "componentTargets": { "type": "integer" },
        "surfaces": { "type": "integer" },
        "renderChains": { "type": "integer" },
        "rendererIds": { "type": "integer" },
        "uniqueExtensions": { "type": "integer" },
        "wrapperFamilyTargets": { "type": "integer" },
        "exhaustiveComponentRenderTargets": { "type": "integer" }
      }
    },
    "packageGroups": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "releaseChannels": {
      "type": "array",
      "items": { "$ref": "#/$defs/releaseChannel" }
    },
    "productionTargets": {
      "type": "array",
      "items": { "$ref": "#/$defs/productionTarget" }
    },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface" }
    },
    "packages": {
      "type": "array",
      "items": { "$ref": "#/$defs/package" }
    },
    "componentTargets": {
      "type": "array",
      "items": { "$ref": "#/$defs/componentTarget" }
    },
    "renderChains": {
      "type": "array",
      "items": { "$ref": "#/$defs/renderChain" }
    },
    "wrapperFamilyTargets": {
      "type": "array",
      "items": { "$ref": "#/$defs/wrapperFamilyTarget" }
    },
    "matrixTargets": {
      "type": "array",
      "items": { "$ref": "#/$defs/matrixTarget" }
    },
    "specialBrowserChecks": {
      "type": "array",
      "items": { "$ref": "#/$defs/specialBrowserCheck" }
    },
    "assetFamilies": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "releaseArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["includeTarball"],
      "properties": {
        "includeTarball": { "type": "boolean" },
        "duplicateOf": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "releaseChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "blocking"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "blocking": { "type": "boolean" }
      }
    },
    "productionTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url", "buildScript", "deployScript", "blocking"],
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "buildScript": { "type": "string" },
        "deployScript": { "type": "string" },
        "blocking": { "type": "boolean" }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "appliesTo", "requiredEntryFormats"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "appliesTo": { "$ref": "#/$defs/stringArray" },
        "requiredEntryFormats": { "$ref": "#/$defs/stringArray" }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "packageName",
        "version",
        "packageDir",
        "tarball",
        "publicSource",
        "releaseArtifact",
        "targetPackage",
        "releaseVersion",
        "github",
        "gitee",
        "sourceRepository",
        "releaseGroup",
        "blocking",
        "entryFormats"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["core", "renderer", "preset", "compatibility", "standard-wrapper"]
        },
        "packageName": { "type": "string" },
        "version": { "type": "string" },
        "packageDir": { "type": "string" },
        "tarball": { "type": "string" },
        "publicSource": { "type": "boolean" },
        "releaseArtifact": { "$ref": "#/$defs/releaseArtifact" },
        "targetPackage": { "type": ["string", "null"] },
        "releaseVersion": { "type": ["string", "null"] },
        "github": { "type": ["string", "null"] },
        "gitee": { "type": ["string", "null"] },
        "sourceRepository": { "type": ["string", "null"] },
        "releaseGroup": {
          "type": "string",
          "enum": ["core", "renderer", "preset", "compatibility", "component-standard", "component-full"]
        },
        "blocking": { "type": "boolean" },
        "entryFormats": { "$ref": "#/$defs/stringArray" }
      }
    },
    "componentTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "packageName",
        "packageDir",
        "framework",
        "family",
        "flavor",
        "basePackage",
        "surfaces",
        "presetPolicy",
        "entryFormats",
        "historicalPackages"
      ],
      "properties": {
        "id": { "type": "string" },
        "packageName": { "type": "string" },
        "packageDir": { "type": "string" },
        "framework": { "type": "string" },
        "family": {
          "type": "string",
          "enum": ["web", "vue3", "vue2.7", "vue2.6", "react", "react-legacy", "jquery", "svelte"]
        },
        "flavor": {
          "type": "string",
          "enum": ["standard", "full"]
        },
        "basePackage": { "type": ["string", "null"] },
        "surfaces": { "$ref": "#/$defs/stringArray" },
        "presetPolicy": {
          "type": "string",
          "enum": ["preset-all-by-default", "explicit-preset-all"]
        },
        "entryFormats": { "$ref": "#/$defs/stringArray" },
        "historicalPackages": { "$ref": "#/$defs/stringArray" }
      }
    },
    "renderChain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "family",
        "rendererId",
        "extension",
        "sample",
        "smokeSurfaces",
        "assertions"
      ],
      "properties": {
        "id": { "type": "string" },
        "family": { "type": "string" },
        "rendererId": { "type": "string" },
        "extension": { "type": "string" },
        "sample": { "type": "string" },
        "smokeSurfaces": { "$ref": "#/$defs/stringArray" },
        "assertions": { "$ref": "#/$defs/stringArray" }
      }
    },
    "wrapperFamilyTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "rendererId", "extension", "sample", "assertions"],
      "properties": {
        "family": { "type": "string" },
        "rendererId": { "type": "string" },
        "extension": { "type": "string" },
        "sample": { "type": "string" },
        "assertions": { "$ref": "#/$defs/stringArray" }
      }
    },
    "matrixTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "componentId",
        "packageName",
        "componentFlavor",
        "presetPolicy",
        "surfaces",
        "renderChainId",
        "rendererId",
        "extension",
        "sample",
        "assertions"
      ],
      "properties": {
        "id": { "type": "string" },
        "componentId": { "type": "string" },
        "packageName": { "type": "string" },
        "componentFlavor": {
          "type": "string",
          "enum": ["standard", "full"]
        },
        "presetPolicy": {
          "type": "string",
          "enum": ["preset-all-by-default", "explicit-preset-all"]
        },
        "surfaces": { "$ref": "#/$defs/stringArray" },
        "renderChainId": { "type": "string" },
        "rendererId": { "type": "string" },
        "extension": { "type": "string" },
        "sample": { "type": "string" },
        "assertions": { "$ref": "#/$defs/stringArray" }
      }
    },
    "specialBrowserCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "script", "covers"],
      "properties": {
        "id": { "type": "string" },
        "script": { "type": "string" },
        "covers": { "$ref": "#/$defs/stringArray" }
      }
    }
  }
}

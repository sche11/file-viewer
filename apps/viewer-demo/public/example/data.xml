<?xml version="1.0" encoding="UTF-8"?>
<preview-suite name="Flyfish Viewer" version="2.2.0">
  <environment framework="vue3" bundler="vite" />

  <groups>
    <group id="document" label="Documents">
      <format extension="docx" renderer="@file-viewer/docx" async="true" />
      <format extension="rtf" renderer="rtf.js" async="true" />
      <format extension="odt" renderer="open-document" async="true" />
      <format extension="ppt" renderer="@file-viewer/ppt@0.3.1" async="true" worker="true" offscreen-canvas="true" wasm="true" font-pack="true" frame-cache="bounded" />
      <format extension="pptx" renderer="@file-viewer/pptx" async="true" worker="true" />
      <format extension="pdf" renderer="pdfjs-dist" navigation="true" />
      <format extension="ofd" renderer="DLTech21/ofd.js" async="true" />
      <format extension="typ" renderer="typst.ts" async="true" paged="true" />
      <format extension="typst" renderer="typst.ts" async="true" paged="true" />
    </group>
    <group id="drawing" label="CAD">
      <format extension="dxf" renderer="@flyfish-dev/cad-viewer" pan="true" zoom="true" />
      <format extension="dwg" renderer="@flyfish-dev/cad-viewer" worker="true" wasm="true" />
      <format extension="dwf" renderer="@flyfish-dev/cad-viewer" native="true" />
      <format extension="dwfx" renderer="@flyfish-dev/cad-viewer" native="true" />
      <format extension="xps" renderer="@flyfish-dev/cad-viewer" native="true" />
      <format extension="geojson" renderer="geojson-svg" async="true" />
      <format extension="kml" renderer="@tmcw/togeojson" async="true" />
      <format extension="gpx" renderer="@tmcw/togeojson" async="true" />
      <format extension="excalidraw" renderer="@excalidraw/excalidraw" async="true" />
      <format extension="drawio" renderer="diagrams.net GraphViewer" async="true" />
      <format extension="dio" renderer="diagrams.net GraphViewer" async="true" />
    </group>
    <group id="model" label="3D Models">
      <format extension="gltf" renderer="three.js" async="true" />
      <format extension="obj" renderer="three.js" async="true" />
      <format extension="stl" renderer="three.js" async="true" />
      <format extension="ply" renderer="three.js" async="true" />
      <format extension="step" renderer="occt-import-js" async="true" worker="true" wasm="true" />
      <format extension="stp" renderer="occt-import-js" async="true" worker="true" wasm="true" />
      <format extension="iges" renderer="occt-import-js" async="true" worker="true" wasm="true" />
      <format extension="igs" renderer="occt-import-js" async="true" worker="true" wasm="true" />
      <format extension="brep" renderer="occt-import-js" async="true" worker="true" wasm="true" />
      <format extension="ifc" renderer="geometry-guidance" async="true" />
      <format extension="3dm" renderer="geometry-guidance" async="true" />
    </group>
    <group id="source" label="Code and Data">
      <format extension="ts" renderer="highlight.js" />
      <format extension="jsonc" renderer="highlight.js" />
      <format extension="toml" renderer="highlight.js" />
      <format extension="proto" renderer="highlight.js" />
      <format extension="json" renderer="highlight.js" />
      <format extension="vue" renderer="highlight.js" />
    </group>
    <group id="asset-data" label="Assets and Data">
      <format extension="sqlite" renderer="sql.js" async="true" />
      <format extension="wasm" renderer="WebAssembly.Module" async="true" />
      <format extension="psd" renderer="ag-psd" async="true" />
    </group>
    <group id="ebook" label="Ebooks">
      <format extension="epub" renderer="epubjs" async="true" />
      <format extension="umd" renderer="umd-parser" async="true" />
    </group>
  </groups>

  <smoke-tests>
    <test id="picker-default" expected="first-group-open" />
    <test id="pdf-fit-width" expected="toolbar-and-nav-visible" />
    <test id="model-viewer" expected="render-or-clear-guidance" />
    <test id="code-highlight" expected="escaped-source" />
  </smoke-tests>
</preview-suite>

{
  "name": "file-viewer-copy-assets",
  "version": "2.1.27",
  "private": false,
  "type": "module",
  "description": "Official npx CLI for copying Flyfish File Viewer Worker, WASM, font, and vendor assets into self-hosted web projects.",
  "keywords": [
    "file-viewer",
    "document-preview",
    "npx",
    "cli",
    "worker",
    "wasm",
    "offline",
    "self-hosted"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyfish-dev/file-viewer.git",
    "directory": "packages/tools/copy-assets"
  },
  "homepage": "https://doc.file-viewer.app/guide/distribution",
  "bugs": {
    "url": "https://github.com/flyfish-dev/file-viewer/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/wybaby168"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "file-viewer-copy-assets": "./dist/cli.js"
  },
  "files": [
    "dist",
    "viewer",
    "README.md",
    "README.en.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm test",
    "stage-assets": "node scripts/stage-assets.mjs",
    "prepack": "pnpm stage-assets",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  },
  "license": "Apache-2.0"
}

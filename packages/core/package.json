{
  "name": "@file-viewer/core",
  "version": "2.2.0",
  "private": false,
  "type": "module",
  "description": "Framework-neutral modular TypeScript core for Flyfish File Viewer renderer orchestration, lifecycle APIs, search, zoom, print, and export",
  "keywords": [
    "file-viewer",
    "document-preview",
    "typescript",
    "core",
    "document-viewer",
    "file-preview",
    "self-hosted",
    "browser",
    "wasm",
    "office-viewer",
    "pdf-viewer"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Wangyu",
    "email": "wybaby168@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyfish-dev/file-viewer-core.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/flyfish-dev/file-viewer-core/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://dev.flyfish.group/donate?source=npm"
  },
  "homepage": "https://doc.file-viewer.app/",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./assets": {
      "types": "./dist/assets.d.ts",
      "import": "./dist/assets.js",
      "default": "./dist/assets.js"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "import": "./dist/headless.js",
      "default": "./dist/headless.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./print-mask": {
      "types": "./dist/print-mask.d.ts",
      "import": "./dist/print-mask.js",
      "default": "./dist/print-mask.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "assets.js",
    "assets.d.ts",
    "browser.js",
    "browser.d.ts",
    "dist",
    "headless.js",
    "headless.d.ts",
    "print-mask.js",
    "print-mask.d.ts",
    "vendor",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -b tsconfig.json --force && node scripts/fix-core-esm-extensions.mjs",
    "type-check": "tsc -b tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "license": "Apache-2.0"
}

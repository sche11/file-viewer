{
  "name": "@file-viewer/renderer-media",
  "version": "2.2.0",
  "private": false,
  "type": "module",
  "description": "Standalone audio and video renderer plugin for Flyfish File Viewer with native media playback, HLS fallback, MIDI parsing, and offline-friendly lazy loading.",
  "keywords": [
    "file-viewer",
    "renderer",
    "audio",
    "video",
    "hls",
    "midi",
    "document-preview",
    "document-viewer",
    "file-preview",
    "self-hosted"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Wangyu",
    "email": "wybaby168@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyfish-dev/file-viewer.git",
    "directory": "packages/renderers/media"
  },
  "homepage": "https://doc.file-viewer.app/guide/on-demand-renderers",
  "bugs": {
    "url": "https://github.com/flyfish-dev/file-viewer/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://dev.flyfish.group/donate?source=npm"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "type-check": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@file-viewer/core": "workspace:2.2.0",
    "@tonejs/midi": "^2.0.28",
    "hls.js": "^1.6.16"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "license": "Apache-2.0"
}

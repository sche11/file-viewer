{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "DOM",
      "ES2020"
    ],
    "strict": true,
    "composite": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/ambient.d.ts",
    "src/index.ts",
    "src/types.ts",
    "src/options.ts",
    "src/styles.ts",
    "src/chart.ts",
    "src/worker.ts",
    "src/viewer.ts"
  ]
}

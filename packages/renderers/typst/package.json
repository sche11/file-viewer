{
  "name": "@file-viewer/renderer-typst",
  "version": "2.1.16",
  "private": false,
  "type": "module",
  "description": "Standalone Typst renderer plugin for Flyfish File Viewer powered by browser WASM.",
  "keywords": [
    "file-viewer",
    "renderer",
    "typst",
    "wasm",
    "document-preview",
    "document-viewer",
    "file-preview",
    "self-hosted"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Wangyu",
    "email": "wybaby168@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyfish-dev/file-viewer.git",
    "directory": "packages/renderers/typst"
  },
  "homepage": "https://doc.file-viewer.app/guide/on-demand-renderers",
  "bugs": {
    "url": "https://github.com/flyfish-dev/file-viewer/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://dev.flyfish.group/shop"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "type-check": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@file-viewer/core": "workspace:^2.1.16",
    "@myriaddreamin/typst-ts-renderer": "0.7.0",
    "@myriaddreamin/typst-ts-web-compiler": "0.7.0",
    "@myriaddreamin/typst.ts": "0.7.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "license": "Apache-2.0"
}

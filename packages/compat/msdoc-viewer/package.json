{
  "name": "msdoc-viewer",
  "version": "0.2.1",
  "private": false,
  "type": "module",
  "description": "Historical compatibility alias for @file-viewer/doc.",
  "keywords": [
    "msdoc-viewer",
    "file-viewer",
    "doc",
    "ms-doc",
    "word",
    "alias",
    "document-preview",
    "file-preview",
    "self-hosted"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Wangyu",
    "email": "wybaby168@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyfish-dev/file-viewer.git",
    "directory": "packages/compat/msdoc-viewer"
  },
  "homepage": "https://github.com/flyfish-dev/docjs",
  "bugs": {
    "url": "https://github.com/flyfish-dev/docjs/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://dev.flyfish.group/donate?source=npm"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js",
      "default": "./dist/worker.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "type-check": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@file-viewer/doc": "workspace:^2.1.18"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}

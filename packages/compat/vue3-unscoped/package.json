{
  "name": "file-viewer3",
  "version": "2.2.0",
  "private": false,
  "type": "module",
  "description": "Compatibility alias package for Flyfish File Viewer Vue 3",
  "keywords": [
    "file-viewer",
    "document-preview",
    "vue3",
    "office-preview",
    "pdf-viewer",
    "document-viewer",
    "file-preview",
    "self-hosted"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Wangyu",
    "email": "wybaby168@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyfish-dev/file-viewer.git",
    "directory": "packages/compat/vue3-unscoped"
  },
  "homepage": "https://doc.file-viewer.app/",
  "bugs": {
    "url": "https://github.com/flyfish-dev/file-viewer/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://dev.flyfish.group/donate?source=npm"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/file-viewer3.css": "./dist/file-viewer3.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "type-check": "node scripts/build.mjs"
  },
  "peerDependencies": {
    "vue": ">=3.3 <4"
  },
  "dependencies": {
    "@file-viewer/vue3": "workspace:2.2.0"
  },
  "license": "Apache-2.0"
}
